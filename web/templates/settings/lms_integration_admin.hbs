{{!
    LMS Integration Admin Panel
    Provides comprehensive interface for realm administrators to manage LMS integration.
}}

<div id="lms-integration-settings" class="settings-section" data-name="lms-integration">

    {{! LMS Integration Status Header }}
    <div class="lms-status-header">
        <div class="settings_panel_list_header">
            <h3>{{t "LMS Integration"}}</h3>
            <div class="lms-status-indicator">
                <span class="lms-status-badge" id="lms-status-badge">{{t "Checking..."}}</span>
                <button class="btn btn-outline reload-lms-status" id="reload-lms-status">
                    <i class="fa fa-refresh"></i> {{t "Refresh Status"}}
                </button>
            </div>
        </div>
        <div class="alert" id="lms-integration-status"></div>
    </div>

    {{! LMS Integration Tabs }}
    <div class="lms-integration-tabs">
        <ul class="nav nav-tabs" role="tablist">
            <li class="nav-item">
                <a class="nav-link active" href="#lms-dashboard" role="tab" data-toggle="tab">
                    <i class="fa fa-dashboard"></i> {{t "Dashboard"}}
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#lms-user-sync" role="tab" data-toggle="tab">
                    <i class="fa fa-users"></i> {{t "User Sync"}}
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#lms-batch-management" role="tab" data-toggle="tab">
                    <i class="fa fa-layer-group"></i> {{t "Batch Management"}}
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#lms-activity-monitoring" role="tab" data-toggle="tab">
                    <i class="fa fa-chart-line"></i> {{t "Activity Monitoring"}}
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#lms-configuration" role="tab" data-toggle="tab">
                    <i class="fa fa-cog"></i> {{t "Configuration"}}
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#lms-logs" role="tab" data-toggle="tab">
                    <i class="fa fa-file-text"></i> {{t "Logs & Debug"}}
                </a>
            </li>
        </ul>

        <div class="tab-content">

            {{! Dashboard Tab }}
            <div class="tab-pane active" id="lms-dashboard" role="tabpanel">
                <div class="lms-dashboard-content">

                    {{! Quick Stats Cards }}
                    <div class="lms-stats-grid">
                        <div class="lms-stat-card">
                            <div class="stat-icon">
                                <i class="fa fa-users"></i>
                            </div>
                            <div class="stat-content">
                                <div class="stat-number" id="total-synced-users">—</div>
                                <div class="stat-label">{{t "Synced Users"}}</div>
                            </div>
                        </div>

                        <div class="lms-stat-card">
                            <div class="stat-icon">
                                <i class="fa fa-graduation-cap"></i>
                            </div>
                            <div class="stat-content">
                                <div class="stat-number" id="total-students">—</div>
                                <div class="stat-label">{{t "Students"}}</div>
                            </div>
                        </div>

                        <div class="lms-stat-card">
                            <div class="stat-icon">
                                <i class="fa fa-chalkboard-teacher"></i>
                            </div>
                            <div class="stat-content">
                                <div class="stat-number" id="total-mentors">—</div>
                                <div class="stat-label">{{t "Mentors"}}</div>
                            </div>
                        </div>

                        <div class="lms-stat-card">
                            <div class="stat-icon">
                                <i class="fa fa-layer-group"></i>
                            </div>
                            <div class="stat-content">
                                <div class="stat-number" id="total-batches">—</div>
                                <div class="stat-label">{{t "Active Batches"}}</div>
                            </div>
                        </div>
                    </div>

                    {{! Recent Activity Summary }}
                    <div class="lms-dashboard-section">
                        <h4>{{t "Recent Activity"}}</h4>
                        <div class="recent-activity-summary">
                            <div class="activity-item">
                                <span class="activity-time" id="last-sync-time">—</span>
                                <span class="activity-description">{{t "Last User Sync"}}</span>
                            </div>
                            <div class="activity-item">
                                <span class="activity-time" id="last-activity-check">—</span>
                                <span class="activity-description">{{t "Last Activity Check"}}</span>
                            </div>
                            <div class="activity-item">
                                <span class="activity-count" id="pending-notifications">—</span>
                                <span class="activity-description">{{t "Pending Notifications"}}</span>
                            </div>
                        </div>
                    </div>

                    {{! Quick Actions }}
                    <div class="lms-dashboard-section">
                        <h4>{{t "Quick Actions"}}</h4>
                        <div class="quick-actions">
                            <button class="btn btn-primary" id="trigger-full-sync">
                                <i class="fa fa-sync"></i> {{t "Full User Sync"}}
                            </button>
                            <button class="btn btn-outline" id="test-lms-connection">
                                <i class="fa fa-plug"></i> {{t "Test LMS Connection"}}
                            </button>
                            <button class="btn btn-outline" id="check-activities">
                                <i class="fa fa-search"></i> {{t "Check Activities"}}
                            </button>
                        </div>
                    </div>

                </div>
            </div>

            {{! User Sync Tab }}
            <div class="tab-pane" id="lms-user-sync" role="tabpanel">
                <div class="lms-user-sync-content">

                    {{! Sync Controls }}
                    <div class="sync-controls">
                        <h4>{{t "User Synchronization"}}</h4>
                        <div class="sync-options">
                            <div class="sync-option-group">
                                <label>{{t "Sync Type"}}</label>
                                <div class="radio-group">
                                    <label class="radio-option">
                                        <input type="radio" name="sync_type" value="all" checked>
                                        {{t "All Users (Students + Mentors)"}}
                                    </label>
                                    <label class="radio-option">
                                        <input type="radio" name="sync_type" value="students">
                                        {{t "Students Only"}}
                                    </label>
                                    <label class="radio-option">
                                        <input type="radio" name="sync_type" value="mentors">
                                        {{t "Mentors Only"}}
                                    </label>
                                </div>
                            </div>

                            <div class="sync-option-group">
                                <label class="checkbox-option">
                                    <input type="checkbox" id="sync_batches" checked>
                                    {{t "Include Batch/Group Management"}}
                                </label>
                            </div>

                            <div class="sync-action">
                                <button class="btn btn-primary" id="start-user-sync">
                                    <i class="fa fa-play"></i> {{t "Start Sync"}}
                                </button>
                                <div class="sync-progress" id="sync-progress" style="display: none;">
                                    <div class="progress-bar">
                                        <div class="progress-fill" id="sync-progress-fill"></div>
                                    </div>
                                    <div class="progress-text" id="sync-progress-text">{{t "Preparing sync..."}}</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    {{! Sync History }}
                    <div class="sync-history">
                        <h4>{{t "Sync History"}}</h4>
                        <div class="progressive-table-wrapper">
                            <table class="table table-striped wrapped-table">
                                <thead>
                                    <tr>
                                        <th data-sort="timestamp">{{t "Time"}}</th>
                                        <th data-sort="type">{{t "Type"}}</th>
                                        <th data-sort="status">{{t "Status"}}</th>
                                        <th>{{t "Created"}}</th>
                                        <th>{{t "Updated"}}</th>
                                        <th>{{t "Skipped"}}</th>
                                        <th>{{t "Errors"}}</th>
                                        <th>{{t "Duration"}}</th>
                                    </tr>
                                </thead>
                                <tbody id="sync-history-table"></tbody>
                            </table>
                        </div>
                    </div>

                    {{! Synced Users List }}
                    <div class="synced-users">
                        <div class="settings_panel_list_header">
                            <h4>{{t "Synced Users"}}</h4>
                            <div class="user_filters">
                                <select class="user-type-filter" id="user-type-filter">
                                    <option value="">{{t "All User Types"}}</option>
                                    <option value="student">{{t "Students"}}</option>
                                    <option value="mentor">{{t "Mentors"}}</option>
                                </select>
                                <input type="text" class="search-input" id="user-search" placeholder="{{t 'Search users...'}}">
                            </div>
                        </div>
                        <div class="progressive-table-wrapper">
                            <table class="table table-striped wrapped-table">
                                <thead>
                                    <tr>
                                        <th data-sort="name">{{t "Name"}}</th>
                                        <th data-sort="email">{{t "Email"}}</th>
                                        <th data-sort="type">{{t "Type"}}</th>
                                        <th data-sort="lms_id">{{t "LMS ID"}}</th>
                                        <th data-sort="last_sync">{{t "Last Sync"}}</th>
                                        <th data-sort="status">{{t "Status"}}</th>
                                        <th class="actions">{{t "Actions"}}</th>
                                    </tr>
                                </thead>
                                <tbody id="synced-users-table"></tbody>
                            </table>
                        </div>
                    </div>

                </div>
            </div>

            {{! Batch Management Tab }}
            <div class="tab-pane" id="lms-batch-management" role="tabpanel">
                <div class="lms-batch-content">

                    <h4>{{t "Batch to Group Mapping"}}</h4>
                    <p class="help-text">{{t "LMS batches are automatically mapped to Zulip user groups for organization and mentoring."}}</p>

                    <div class="batch-controls">
                        <button class="btn btn-primary" id="sync-batches">
                            <i class="fa fa-sync"></i> {{t "Sync Batches"}}
                        </button>
                        <button class="btn btn-outline" id="create-batch-group">
                            <i class="fa fa-plus"></i> {{t "Create Group Manually"}}
                        </button>
                    </div>

                    <div class="progressive-table-wrapper">
                        <table class="table table-striped wrapped-table">
                            <thead>
                                <tr>
                                    <th data-sort="batch_name">{{t "LMS Batch"}}</th>
                                    <th data-sort="group_name">{{t "Zulip Group"}}</th>
                                    <th data-sort="student_count">{{t "Students"}}</th>
                                    <th data-sort="mentor_count">{{t "Mentors"}}</th>
                                    <th data-sort="last_sync">{{t "Last Sync"}}</th>
                                    <th data-sort="status">{{t "Status"}}</th>
                                    <th class="actions">{{t "Actions"}}</th>
                                </tr>
                            </thead>
                            <tbody id="batch-groups-table"></tbody>
                        </table>
                    </div>

                </div>
            </div>

            {{! Activity Monitoring Tab }}
            <div class="tab-pane" id="lms-activity-monitoring" role="tabpanel">
                <div class="lms-activity-content">

                    {{! Activity Stats }}
                    <div class="activity-stats">
                        <h4>{{t "Activity Monitoring Status"}}</h4>
                        <div class="activity-stats-grid">
                            <div class="stat-item">
                                <span class="stat-label">{{t "Monitor Status"}}</span>
                                <span class="stat-value" id="monitor-status">—</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-label">{{t "Last Check"}}</span>
                                <span class="stat-value" id="last-activity-poll">—</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-label">{{t "Events Today"}}</span>
                                <span class="stat-value" id="events-today">—</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-label">{{t "Notifications Sent"}}</span>
                                <span class="stat-value" id="notifications-sent">—</span>
                            </div>
                        </div>
                    </div>

                    {{! Activity Controls }}
                    <div class="activity-controls">
                        <button class="btn btn-primary" id="poll-activities">
                            <i class="fa fa-search"></i> {{t "Check for New Activities"}}
                        </button>
                        <button class="btn btn-outline" id="process-pending-events">
                            <i class="fa fa-cogs"></i> {{t "Process Pending Events"}}
                        </button>
                    </div>

                    {{! Recent Activities }}
                    <div class="recent-activities">
                        <div class="settings_panel_list_header">
                            <h4>{{t "Recent LMS Activities"}}</h4>
                            <div class="activity_filters">
                                <select class="activity-type-filter" id="activity-type-filter">
                                    <option value="">{{t "All Event Types"}}</option>
                                    <option value="exam_started">{{t "Exam Started"}}</option>
                                    <option value="exam_completed">{{t "Exam Completed"}}</option>
                                    <option value="exam_passed">{{t "Exam Passed"}}</option>
                                    <option value="exam_failed">{{t "Exam Failed"}}</option>
                                    <option value="content_started">{{t "Content Started"}}</option>
                                    <option value="content_completed">{{t "Content Completed"}}</option>
                                    <option value="content_watched">{{t "Content Watched"}}</option>
                                </select>
                                <input type="text" class="search-input" id="activity-search" placeholder="{{t 'Search activities...'}}">
                            </div>
                        </div>
                        <div class="progressive-table-wrapper">
                            <table class="table table-striped wrapped-table">
                                <thead>
                                    <tr>
                                        <th data-sort="timestamp">{{t "Time"}}</th>
                                        <th data-sort="event_type">{{t "Event Type"}}</th>
                                        <th data-sort="student">{{t "Student"}}</th>
                                        <th data-sort="activity">{{t "Activity"}}</th>
                                        <th data-sort="mentor_notified">{{t "Mentor Notified"}}</th>
                                        <th data-sort="status">{{t "Status"}}</th>
                                        <th class="actions">{{t "Actions"}}</th>
                                    </tr>
                                </thead>
                                <tbody id="activity-events-table"></tbody>
                            </table>
                        </div>
                    </div>

                </div>
            </div>

            {{! Configuration Tab }}
            <div class="tab-pane" id="lms-configuration" role="tabpanel">
                <form class="admin-realm-form lms-configuration-form">

                    {{! Database Configuration }}
                    <div class="settings-subsection-parent">
                        <div class="subsection-header">
                            <h3>{{t "LMS Database Connection"}}</h3>
                            {{> settings_save_discard_widget section_name="lms-database" }}
                        </div>

                        <div class="organization-settings-parent">
                            <div class="input-group admin-realm">
                                <label for="id_lms_enabled">{{t "Enable LMS Integration"}}</label>
                                <input type="checkbox" id="id_lms_enabled"
                                       name="lms_enabled" class="setting-widget"
                                       data-setting-widget-type="bool"
                                       {{#if lms_enabled}}checked{{/if}} />
                                <div class="help-text">{{t "Enable synchronization and activity monitoring with the LMS."}}</div>
                            </div>

                            <div class="input-group admin-realm">
                                <label for="id_lms_db_host">{{t "Database Host"}}</label>
                                <input type="text" id="id_lms_db_host" name="lms_db_host"
                                       class="setting-widget" value="{{ lms_db_host }}" />
                            </div>

                            <div class="input-group admin-realm">
                                <label for="id_lms_db_port">{{t "Database Port"}}</label>
                                <input type="number" id="id_lms_db_port" name="lms_db_port"
                                       class="setting-widget" value="{{ lms_db_port }}" min="1" max="65535" />
                            </div>

                            <div class="input-group admin-realm">
                                <label for="id_lms_db_name">{{t "Database Name"}}</label>
                                <input type="text" id="id_lms_db_name" name="lms_db_name"
                                       class="setting-widget" value="{{ lms_db_name }}" />
                            </div>

                            <div class="input-group admin-realm">
                                <label for="id_lms_db_username">{{t "Database Username"}}</label>
                                <input type="text" id="id_lms_db_username" name="lms_db_username"
                                       class="setting-widget" value="{{ lms_db_username }}" />
                            </div>

                            <div class="input-group admin-realm">
                                <label for="id_lms_db_password">{{t "Database Password"}}</label>
                                <input type="password" id="id_lms_db_password" name="lms_db_password"
                                       class="setting-widget" placeholder="••••••••" />
                            </div>

                            <div class="test-connection">
                                <button type="button" class="btn btn-outline" id="test-db-connection">
                                    <i class="fa fa-plug"></i> {{t "Test Database Connection"}}
                                </button>
                                <div class="connection-status" id="db-connection-status"></div>
                            </div>
                        </div>
                    </div>

                    {{! Webhook Configuration }}
                    <div class="settings-subsection-parent">
                        <div class="subsection-header">
                            <h3>{{t "Webhook Configuration"}}</h3>
                            {{> settings_save_discard_widget section_name="lms-webhook" }}
                        </div>

                        <div class="organization-settings-parent">
                            <div class="input-group admin-realm">
                                <label for="id_webhook_secret">{{t "Webhook Secret"}}</label>
                                <input type="password" id="id_webhook_secret" name="webhook_secret"
                                       class="setting-widget" placeholder="••••••••" />
                                <div class="help-text">{{t "Secret token used to authenticate webhook requests from the LMS."}}</div>
                            </div>

                            <div class="webhook-endpoint">
                                <label>{{t "Webhook Endpoint URL"}}</label>
                                <div class="endpoint-url">
                                    <code id="webhook-endpoint-url">{{ webhook_endpoint_url }}</code>
                                    <button type="button" class="btn btn-sm" id="copy-webhook-url">
                                        <i class="fa fa-copy"></i> {{t "Copy"}}
                                    </button>
                                </div>
                                <div class="help-text">{{t "Configure this URL in your LMS to receive user creation notifications."}}</div>
                            </div>
                        </div>
                    </div>

                    {{! JWT Authentication }}
                    <div class="settings-subsection-parent">
                        <div class="subsection-header">
                            <h3>{{t "TestPress JWT Authentication"}}</h3>
                            {{> settings_save_discard_widget section_name="lms-jwt" }}
                        </div>

                        <div class="organization-settings-parent">
                            <div class="input-group admin-realm">
                                <label for="id_jwt_enabled">{{t "Enable JWT Authentication"}}</label>
                                <input type="checkbox" id="id_jwt_enabled"
                                       name="jwt_enabled" class="setting-widget"
                                       data-setting-widget-type="bool"
                                       {{#if jwt_enabled}}checked{{/if}} />
                                <div class="help-text">{{t "Allow users to authenticate using TestPress JWT tokens."}}</div>
                            </div>

                            <div class="input-group admin-realm">
                                <label for="id_testpress_api_url">{{t "TestPress API Base URL"}}</label>
                                <input type="url" id="id_testpress_api_url" name="testpress_api_url"
                                       class="setting-widget" value="{{ testpress_api_url }}" />
                            </div>

                            <div class="test-jwt">
                                <button type="button" class="btn btn-outline" id="test-jwt-config">
                                    <i class="fa fa-key"></i> {{t "Test JWT Configuration"}}
                                </button>
                                <div class="jwt-status" id="jwt-config-status"></div>
                            </div>
                        </div>
                    </div>

                    {{! Activity Monitoring Settings }}
                    <div class="settings-subsection-parent">
                        <div class="subsection-header">
                            <h3>{{t "Activity Monitoring"}}</h3>
                            {{> settings_save_discard_widget section_name="lms-activity" }}
                        </div>

                        <div class="organization-settings-parent">
                            <div class="input-group admin-realm">
                                <label for="id_activity_monitor_enabled">{{t "Enable Activity Monitoring"}}</label>
                                <input type="checkbox" id="id_activity_monitor_enabled"
                                       name="activity_monitor_enabled" class="setting-widget"
                                       data-setting-widget-type="bool"
                                       {{#if activity_monitor_enabled}}checked{{/if}} />
                                <div class="help-text">{{t "Monitor student activities in the LMS and send notifications to mentors."}}</div>
                            </div>

                            <div class="input-group admin-realm">
                                <label for="id_poll_interval">{{t "Poll Interval (seconds)"}}</label>
                                <input type="number" id="id_poll_interval" name="poll_interval"
                                       class="setting-widget" value="{{ poll_interval }}" min="30" max="3600" />
                                <div class="help-text">{{t "How often to check for new activities (30-3600 seconds)."}}</div>
                            </div>

                            <div class="input-group admin-realm">
                                <label for="id_notify_mentors">{{t "Notify Mentors"}}</label>
                                <input type="checkbox" id="id_notify_mentors"
                                       name="notify_mentors" class="setting-widget"
                                       data-setting-widget-type="bool"
                                       {{#if notify_mentors}}checked{{/if}} />
                                <div class="help-text">{{t "Send private messages to mentors when their students complete activities."}}</div>
                            </div>
                        </div>
                    </div>

                </form>
            </div>

            {{! Logs Tab }}
            <div class="tab-pane" id="lms-logs" role="tabpanel">
                <div class="lms-logs-content">

                    <div class="logs-controls">
                        <h4>{{t "Logs and Debugging"}}</h4>
                        <div class="log-filters">
                            <select class="log-level-filter" id="log-level-filter">
                                <option value="">{{t "All Levels"}}</option>
                                <option value="ERROR">{{t "Errors Only"}}</option>
                                <option value="WARNING">{{t "Warnings"}}</option>
                                <option value="INFO">{{t "Info"}}</option>
                                <option value="DEBUG">{{t "Debug"}}</option>
                            </select>
                            <select class="log-source-filter" id="log-source-filter">
                                <option value="">{{t "All Sources"}}</option>
                                <option value="user_sync">{{t "User Sync"}}</option>
                                <option value="activity_monitor">{{t "Activity Monitor"}}</option>
                                <option value="webhook">{{t "Webhook"}}</option>
                                <option value="jwt_auth">{{t "JWT Auth"}}</option>
                            </select>
                            <button class="btn btn-outline" id="refresh-logs">
                                <i class="fa fa-refresh"></i> {{t "Refresh"}}
                            </button>
                            <button class="btn btn-outline" id="download-logs">
                                <i class="fa fa-download"></i> {{t "Download"}}
                            </button>
                        </div>
                    </div>

                    <div class="error-summary">
                        <h5>{{t "Recent Errors"}}</h5>
                        <div class="error-stats">
                            <div class="error-stat">
                                <span class="error-count" id="sync-errors-count">—</span>
                                <span class="error-label">{{t "Sync Errors"}}</span>
                            </div>
                            <div class="error-stat">
                                <span class="error-count" id="webhook-errors-count">—</span>
                                <span class="error-label">{{t "Webhook Errors"}}</span>
                            </div>
                            <div class="error-stat">
                                <span class="error-count" id="auth-errors-count">—</span>
                                <span class="error-label">{{t "Auth Errors"}}</span>
                            </div>
                        </div>
                    </div>

                    <div class="logs-display">
                        <div class="progressive-table-wrapper">
                            <table class="table table-striped wrapped-table">
                                <thead>
                                    <tr>
                                        <th data-sort="timestamp">{{t "Time"}}</th>
                                        <th data-sort="level">{{t "Level"}}</th>
                                        <th data-sort="source">{{t "Source"}}</th>
                                        <th data-sort="message">{{t "Message"}}</th>
                                        <th class="actions">{{t "Actions"}}</th>
                                    </tr>
                                </thead>
                                <tbody id="lms-logs-table"></tbody>
                            </table>
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>

</div>